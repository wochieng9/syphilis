def diff_dict(d40, d90):
    keys = list(d40.keys())
    return {f"Δ {k} (prevented)": (np.asarray(d40[k]) - np.asarray(d90[k])) for k in keys}
delta = diff_dict(out_40, out_90)
df_inc = pd.DataFrame(delta)
