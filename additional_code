df_inc = df_inc[["iteration"] + [c for c in df_inc.columns if c != "iteration"]]

# --------------- Correct DALY & QALY mapping ---------------
def AF(t, r): 
    if r==0: return t
    return (1-(1+r)**(-t))/r

r = 0.03
L0 = 86.0
AF_L0 = AF(L0, r)
AF_025 = AF(0.25, r)
AF_10  = AF(1.0, r)
AF_LT  = AF(70.0, r)
AF_PLBW = AF(0.25, r)

col_map = {
    "preterm": "Δ Preterm births (prevented)",
    "lbw": "Δ Low birth weight (prevented)",
    "still": "Δ Stillbirths (≥20w) (prevented)",
    "iufd": "Δ IUFD (≥28w subset) (prevented)",
