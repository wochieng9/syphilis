    "cs_comp": "Δ Congenital syphilis – complicated (prevented)",
    "cs_uncomp": "Δ Congenital syphilis – uncomplicated (prevented)",
}

df_inc["DALYs_prevented_fix"] = 0.0
df_inc["QALYs_gained_fix"] = 0.0

# Neonatal deaths
df_inc["DALYs_prevented_fix"] += df_inc[col_map["neodeath"]]*AF_L0
df_inc["QALYs_gained_fix"]    += df_inc[col_map["neodeath"]]*AF_L0

# CS uncomplicated acute
df_inc["DALYs_prevented_fix"] += df_inc[col_map["cs_uncomp"]]*0.053*AF_025
df_inc["QALYs_gained_fix"]    += df_inc[col_map["cs_uncomp"]]*0.053*AF_025

