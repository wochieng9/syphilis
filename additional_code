# ---------- function to run Monte Carlo ----------
def congenital_mc(n_iter=n_iter, discount_rate=discount_rate, seed=seed):
    np.random.seed(seed)
    samples = np.zeros(n_iter)
    
    # Precompute lognormal params for cost components where applicable
    # Rreat unit cost items via lognormal matching lower/upper as 2.5%/97.5%ile.
    def draw_unit_cost(key):
        comp = cost_components[key]
        return sample_lognormal_from_bounds(comp['low'], comp['high'], size=1)[0]
 
    # precompute beta params for each sequela
    prob_beta_params = {k: beta_params_from_bounds(*probabilities[k]) for k in probabilities}
    
    for i in range(n_iter):
        # --- sample costs ---
        # cardiovascular
        aortic = draw_unit_cost('aortic_valve_replacement')
        cv_follow_year_cost = draw_unit_cost('cv_followup_per_year')
        cv_years = uniform.rvs(loc=cost_components['cv_followup_years']['low'],
                               scale=(cost_components['cv_followup_years']['high'] - cost_components['cv_followup_years']['low']))
        cv_follow_pv = pv_annuity(cv_follow_year_cost, cv_years, discount_rate)
        cost_cardio = aortic + cv_follow_pv
        
        # meningovascular
        meningoence = draw_unit_cost('treatment_for_meningoencephalitis')
        stroke_cost = draw_unit_cost('treatment_for_stroke')
        meningo_lt_cost_per_year = draw_unit_cost('meningo_longterm_care_per_year')
        meningo_lt_years = uniform.rvs(loc=cost_components['meningo_longterm_years']['low'],
                                       scale=(cost_components['meningo_longterm_years']['high'] - cost_components['meningo_longterm_years']['low']))
        meningo_lt_pv = pv_annuity(meningo_lt_cost_per_year, meningo_lt_years, discount_rate)
        # Chesson applied 75% stroke and 17% require long-term care among those with meningovascular (see Appendix)
        # Mirror that structure here, sampling 0.75/0.17 uncertainty via beta if desired; for now use fixed mixture

        cost_meningo = 0.75 * (stroke_cost + 0.17 * meningo_lt_pv) + 0.25 * meningoence
        
        # general paresis
        gp_init = draw_unit_cost('general_paresis_initial')
        gp_lt_per_year = draw_unit_cost('general_paresis_longterm_per_year')
        gp_lt_years = uniform.rvs(loc=cost_components['general_paresis_longterm_years']['low'],
                                  scale=(cost_components['general_paresis_longterm_years']['high'] - cost_components['general_paresis_longterm_years']['low']))
        gp_lt_pv = pv_annuity(gp_lt_per_year, gp_lt_years, discount_rate)
        cost_gp = gp_init + gp_lt_pv
        
        # tabes dorsalis
        tabes_init = draw_unit_cost('tabes_initial')
        tabes_years = uniform.rvs(loc=cost_components['tabes_followup_years']['low'],
                                  scale=(cost_components['tabes_followup_years']['high'] - cost_components['tabes_followup_years']['low']))
        tabes_pv = pv_annuity(draw_unit_cost('tabes_initial'), tabes_years, discount_rate)
        cost_tabes = tabes_init + tabes_pv
        
        # late benign
        late_benign_one = draw_unit_cost('late_benign_one_time')
        cost_late_benign = late_benign_one
        
        # compose dictionary
        sampled_costs = {
            'cardiovascular': cost_cardio,
            'meningovascular': cost_meningo,
            'general_paresis': cost_gp,
            'tabes_dorsalis': cost_tabes,
            'late_benign': cost_late_benign
        }
        
        # --- sample probabilities (conditional on congenital case) ---
        sampled_probs = {k: beta(a=prob_beta_params[k][0], b=prob_beta_params[k][1]).rvs() for k in probabilities}
        
        total_p = sum(sampled_probs.values())
        if total_p <= 0:
            # fallback
            weights = {k: probabilities[k][0] for k in probabilities}
            total_p = sum(weights.values())
            sampled_probs = {k: v/total_p for k, v in weights.items()}
        else:
            sampled_probs = {k: v/total_p for k, v in sampled_probs.items()}
        
        # compute expected cost per congenital case (no 0.033 multiplier)
        expected_case_cost = sum(sampled_probs[k] * sampled_costs[k] for k in sampled_costs)
        samples[i] = expected_case_cost
    
    # return distribution summary
    mean = samples.mean()
    p2_5, p97_5 = np.percentile(samples, [2.5, 97.5])
    return {'mean': mean, '2.5%': p2_5, '97.5%': p97_5, 'samples': samples}
