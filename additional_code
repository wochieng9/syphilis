# ---------------- core simulation ----------------
np.random.seed(2025)
COHORT = 100_000
p_active_syph = 0.01
screen_baseline = 0.40
screen_enhanced = 0.90
sens_serology = 0.98
adequate_tx_given_positive = 0.85
timely_treatment_fraction = 0.85

baseline = {"preterm":{"alpha":1040,"beta":8960},"lbw":{"alpha":850,"beta":9150},
            "stillbirth":{"alpha":55,"beta":9945},"neonatal_death":{"alpha":36,"beta":9964},
            "miscarriage":{"alpha":1500,"beta":8500}}
prop_late_fetal = 0.49
untreated_abs = {"preterm":0.232,"lbw":0.234,"stillbirth":0.264,"miscarriage":0.149,"neonatal_death":0.162,"cs_any":0.360}
tx_rr_params = {"preterm":{"rr":0.48,"lo":0.39,"hi":0.58},
                "lbw":{"rr":0.50,"lo":0.42,"hi":0.59},
                "stillbirth":{"rr":0.21,"lo":0.10,"hi":0.35},
                "neonatal_death":{"rr":0.20,"lo":0.13,"hi":0.32},
                "cs_any":{"rr":0.03,"lo":0.02,"hi":0.07}}
prop_cs_symptomatic = 0.38
N = 10_000

def ln_params_from_ci(m, lo, hi):
    mu = np.log(m); sigma = (np.log(hi)-np.log(lo))/(2*1.96); return mu, sigma
def draw_rr(key, size):
    mu, sigma = ln_params_from_ci(tx_rr_params[key]["rr"],tx_rr_params[key]["lo"],tx_rr_params[key]["hi"])
    return lognorm(s=sigma, scale=np.exp(mu)).rvs(size=size)
def draw_baseline(par): return beta(par["alpha"], par["beta"]).rvs(size=N)
b_preterm = draw_baseline(baseline["preterm"]); b_lbw = draw_baseline(baseline["lbw"])
b_still = draw_baseline(baseline["stillbirth"]); b_neo = draw_baseline(baseline["neonatal_death"])
b_mis = draw_baseline(baseline["miscarriage"])
rr_preterm = draw_rr("preterm", N); rr_lbw = draw_rr("lbw", N); rr_still = draw_rr("stillbirth", N)
rr_neo = draw_rr("neonatal_death", N); rr_cs = draw_rr("cs_any", N)
def beta_from_mean(m, n=1000):
    a=m*n; b=(1-m)*n; return beta(a,b).rvs(size=N)
u_preterm=beta_from_mean(untreated_abs["preterm"]); u_lbw=beta_from_mean(untreated_abs["lbw"])
u_still=beta_from_mean(untreated_abs["stillbirth"]); u_mis=beta_from_mean(untreated_abs["miscarriage"])
u_neo=beta_from_mean(untreated_abs["neonatal_death"]); u_cs=beta_from_mean(untreated_abs["cs_any"])

def strategy_outcomes(screen_cov):
    p_detect = screen_cov * sens_serology
    p_adequate = p_detect * adequate_tx_given_positive * timely_treatment_fraction
    preterm_syph = p_adequate*(u_preterm*rr_preterm) + (1-p_adequate)*u_preterm
    lbw_syph     = p_adequate*(u_lbw*rr_lbw)       + (1-p_adequate)*u_lbw
    still_syph   = p_adequate*(u_still*rr_still)   + (1-p_adequate)*u_still
    neo_syph     = p_adequate*(u_neo*rr_neo)       + (1-p_adequate)*u_neo
    mis_syph     = u_mis
    cs_any_syph  = p_adequate*(u_cs*rr_cs)         + (1-p_adequate)*u_cs
    cs_comp_syph = cs_any_syph * prop_cs_symptomatic
    cs_uncomp_syph = cs_any_syph * (1 - prop_cs_symptomatic)
    p = p_active_syph
    preterm = p*preterm_syph + (1-p)*b_preterm
    lbw     = p*lbw_syph     + (1-p)*b_lbw
    still   = p*still_syph   + (1-p)*b_still
    neo     = p*neo_syph     + (1-p)*b_neo
    mis     = p*mis_syph     + (1-p)*b_mis
    iufd = still * prop_late_fetal
    cs_comp = p * cs_comp_syph
    cs_uncomp = p * cs_uncomp_syph
    def to_counts(x): return np.round(x*COHORT).astype(int)
    return {"Preterm births":to_counts(preterm),
            "Low birth weight":to_counts(lbw),
            "Stillbirths (≥20w)":to_counts(still),
            "IUFD (≥28w subset)":to_counts(iufd),
            "Miscarriages (<20w clinical)":to_counts(mis),
            "Neonatal deaths (<28d)":to_counts(neo),
            "Congenital syphilis – complicated":to_counts(cs_comp),
            "Congenital syphilis – uncomplicated":to_counts(cs_uncomp)}

out_40 = strategy_outcomes(screen_baseline)
out_90 = strategy_outcomes(screen_enhanced)
