```python
# ----------------- Core MC function -----------------
def societal_weighted_mc(
    n_iter=n_iter,
    sequelae_probs=None,
    sequelae_societal_costs=None,
    health_samples=None,
    discount_rate=discount_rate,
    seed=seed,
    sequelae_mutually_exclusive=False,
    premature_mortality_method='human_capital',  # or 'VSL'
    VSL_value=None
):
    """
    Monte Carlo that weights societal cost components by sequela probabilities.

    Parameters
    ----------
    n_iter : int
    sequelae_probs : dict
        keys = sequela names, values = (base_prob, low_prob, high_prob)
    sequelae_societal_costs : dict
        keys = sequela names, values = dict of societal cost elements. Example:
        {
          'cardiovascular': {
              'caregiver_hours_per_year': (base, low, high),
              'caregiver_wage': (base, low, high),
              'care_years': (base, low, high),   # will be sampled uniformly between low and high
              'lost_earnings_per_year': (base, low, high),
              'lost_work_years': (base, low, high),
              'special_ed_cost_per_year': (base, low, high),
              'special_ed_years': (base, low, high),
              'nonmedical_one_time': (base, low, high),
              'prob_death_given_sequela': (base, low, high)  # optional
          },
          ...
        }
    health_samples : array-like length n_iter (per-case health-sector cost)
    sequelae_mutually_exclusive : if True, sampled probs are renormalized to sum=1 (Dirichlet-like)
    premature_mortality_method : 'human_capital' or 'VSL'
    VSL_value : if using 'VSL'
    """
    np.random.seed(seed)

    # fallback health samples if none provided
    if health_samples is None:
        # Health draw 
        health_samples = np.random.lognormal(mean=np.log(42767), sigma=0.5, size=n_iter)
    else:
        health_samples = np.asarray(health_samples)
        if len(health_samples) != n_iter:
            raise ValueError("health_samples length must equal n_iter")

    # prepare prob params
    prob_beta_params = {}
    for s, (base, low, high) in sequelae_probs.items():
        a, b = beta_params_from_bounds(base, low, high)
        prob_beta_params[s] = (a, b)

    # prepare cost param templates for each sequela element & sample per-iteration
    results_samples = np.zeros(n_iter)
    components = {s: np.zeros(n_iter) for s in sequelae_probs}  # per-sequela total societal cost
    comp_breakdown = {}  # dict of dicts for further breakdown 

    # precompute any other parameterizations if needed
    for i in range(n_iter):
        # 1) sample sequela probabilities
        sampled_p = {s: beta(a=prob_beta_params[s][0], b=prob_beta_params[s][1]).rvs()
                     for s in sequelae_probs}

        if sequelae_mutually_exclusive:
            total_p = sum(sampled_p.values())
            if total_p <= 0:
                # fallback to base normalized
                base_vals = {s: sequelae_probs[s][0] for s in sequelae_probs}
                tot = sum(base_vals.values())
                sampled_p = {s: base_vals[s] / tot for s in base_vals}
            else:
                sampled_p = {s: sampled_p[s] / total_p for s in sampled_p}

        # 2) for each sequela, sample societal cost elements, compute per-sequela societal PV,
        #    and multiply by sampled_p[s] (weighting)
        total_societal_for_case = 0.0
        for s, probs in sequelae_probs.items():
            # retrieve the components dict for sequela
            comps = sequelae_societal_costs[s]

            # caregiver hours/year and wage -> annual caregiver cost -> PV over years
            if 'caregiver_hours_per_year' in comps and 'caregiver_wage' in comps and 'care_years' in comps:
                ch_base, ch_low, ch_high = comps['caregiver_hours_per_year']
                cw_base, cw_low, cw_high = comps['caregiver_wage']
                cy_base, cy_low, cy_high = comps['care_years']
                # hours and wage sampled lognormal from bounds; years sampled uniform
                sampled_hours = sample_lognormal_from_bounds(ch_low, ch_high)[0]
                sampled_wage = sample_lognormal_from_bounds(cw_low, cw_high)[0]
                sampled_years = uniform.rvs(loc=cy_low, scale=(cy_high - cy_low))
                caregiver_pv = pv_annuity(sampled_hours * sampled_wage, sampled_years, discount_rate)

            else:
                caregiver_pv = 0.0

            # lost earnings due to morbidity (per year * years)
            if 'lost_earnings_per_year' in comps and 'lost_work_years' in comps and 'employment_rate' in comps:
                le_base, le_low, le_high = comps['lost_earnings_per_year']
                lw_base, lw_low, lw_high = comps['lost_work_years']
                emp_base, emp_low, emp_high = comps['employment_rate']
                sampled_le = sample_lognormal_from_bounds(le_low, le_high)[0]
                sampled_lw = uniform.rvs(loc=lw_low, scale=(lw_high - lw_low))
                # employment rate sample as beta
                a_emp, b_emp = beta_params_from_bounds(emp_base, emp_low, emp_high)
                sampled_emp = beta(a_emp, b_emp).rvs()
                morbidity_pv = sampled_emp * pv_annuity(sampled_le, sampled_lw, discount_rate)
            else:
                morbidity_pv = 0.0

            # special education (annual * years)
            if 'special_ed_cost_per_year' in comps and 'special_ed_years' in comps:
                se_base, se_low, se_high = comps['special_ed_cost_per_year']
                sey_base, sey_low, sey_high = comps['special_ed_years']
                sampled_se_cost = sample_lognormal_from_bounds(se_low, se_high)[0]
                sampled_se_years = uniform.rvs(loc=sey_low, scale=(sey_high - sey_low))
                special_ed_pv = pv_annuity(sampled_se_cost, sampled_se_years, discount_rate)
            else:
                special_ed_pv = 0.0

            # nonmedical one-time cost
            if 'nonmedical_one_time' in comps:
                nm_base, nm_low, nm_high = comps['nonmedical_one_time']
                sampled_nm = sample_lognormal_from_bounds(nm_low, nm_high)[0]
            else:
                sampled_nm = 0.0

            # premature mortality: sequela may have prob_death_given_sequela
            death_cost_pv = 0.0
            if 'prob_death_given_sequela' in comps:
                pd_base, pd_low, pd_high = comps['prob_death_given_sequela']
                a_pd, b_pd = beta_params_from_bounds(pd_base, pd_low, pd_high)
                sampled_pd = beta(a_pd, b_pd).rvs()
                if premature_mortality_method == 'human_capital':
                    # sample remaining working years lost and annual earnings similar to morbidity
                    # use comps fields if present else defaults
                    rem_base, rem_low, rem_high = comps.get('rem_work_years', (30, 0, 45))
                    earn_base, earn_low, earn_high = comps.get('lost_earnings_per_year',
                                                               (40000, 20000, 80000))
                    sampled_rem = uniform.rvs(loc=rem_low, scale=(rem_high - rem_low))
                    sampled_earn = sample_lognormal_from_bounds(earn_low, earn_high)[0]
                    a_emp2, b_emp2 = beta_params_from_bounds(*comps.get('employment_rate', (0.6, 0.3, 0.8)))
                    sampled_emp2 = beta(a_emp2, b_emp2).rvs()
                    death_cost_pv = sampled_pd * sampled_emp2 * pv_annuity(sampled_earn, sampled_rem, discount_rate)
                elif premature_mortality_method == 'VSL':
                    if VSL_value is None:
                        raise ValueError("VSL_value required for VSL method")
                    # sample a small uncertainty around VSL? we will treat VSL as fixed for simplicity
                    death_cost_pv = sampled_pd * VSL_value
            # per-sequela societal cost = sum of PV components (per person with sequela)
            per_sequela_societal = caregiver_pv + morbidity_pv + special_ed_pv + sampled_nm + death_cost_pv

            # weight by sampled sequela probability
            weighted = sampled_p[s] * per_sequela_societal

            components[s][i] = weighted
            total_societal_for_case += weighted

        # total cost for this MC iteration = health sector (per-case) + total societal (weighted)
        results_samples[i] = health_samples[i] + total_societal_for_case

    # Summaries
    def summarize(arr):
