```python
def calc_dalys_beta_both(
    n_cases=1,
    dw_mean=0.315, dw_low=0.159, dw_high=0.471,
    duration_years=10,
    prob_death=0.05,
    life_expectancy_at_death=65,
    discount_rate=discount_rate,
    n_iter=n_iter,
    seed=seed
):
    """
    Monte Carlo estimation of DALYs per case and total, returning BOTH
    discounted and undiscounted estimates. Disability weight sampled as Beta.

    Returns: dict with: mean/95%UI per-case and total for:
      - daly_undiscounted, daly_discounted, components yld/yll both ways
    """
    rs = np.random.RandomState(seed)

    # Sample DW from Beta parameterized by bounds
    a_dw, b_dw = beta_params_from_bounds(dw_mean, dw_low, dw_high)
    dw_samples = beta(a_dw, b_dw).rvs(size=n_iter, random_state=rs)

    # Sample death probability & duration (here simple uniform ±20%)
    pdeath_samples = np.clip(rs.uniform(0.8 * prob_death, 1.2 * prob_death, size=n_iter), 0, 1)
    dur_samples = rs.uniform(0.8 * duration_years, 1.2 * duration_years, size=n_iter)

    # Precompute discounted year-factors
    pv_dur = np.array([pv_years(t, discount_rate) for t in dur_samples])      # PV of duration
    pv_life = pv_years(life_expectancy_at_death, discount_rate)               # PV of life exp (constant)

    # YLD, undiscounted and discounted
    yld_und = (1 - pdeath_samples) * dw_samples * dur_samples
    yld_disc = (1 - pdeath_samples) * dw_samples * pv_dur

    # YLL, undiscounted and discounted
    yll_und = pdeath_samples * life_expectancy_at_death
    yll_disc = pdeath_samples * pv_life

    daly_per_case_und = yld_und + yll_und
    daly_per_case_disc = yld_disc + yll_disc

    # Totals
    total_und = n_cases * daly_per_case_und
    total_disc = n_cases * daly_per_case_disc

    # Summaries
    def summarize(arr):
        return {
            "mean": float(np.mean(arr)),
            "median": float(np.median(arr)),
            "2.5%": float(np.percentile(arr, 2.5)),
            "97.5%": float(np.percentile(arr, 97.5))
        }

    out = {
        "per_case": {
            "DALY_undiscounted": summarize(daly_per_case_und),
            "DALY_discounted": summarize(daly_per_case_disc),
            "YLD_undiscounted": summarize(yld_und),
            "YLD_discounted": summarize(yld_disc),
            "YLL_undiscounted": summarize(yll_und),
            "YLL_discounted": summarize(yll_disc),
        },
        "total": {
            "DALY_undiscounted": summarize(total_und),
            "DALY_discounted": summarize(total_disc)
        },
        # raw arrays if you want to investigate distributions downstream
        "samples": {
            "per_case_undiscounted": daly_per_case_und,
            "per_case_discounted": daly_per_case_disc,
            "yld_und": yld_und,
            "yld_disc": yld_disc,
            "yll_und": yll_und,
            "yll_disc": yll_disc
        }
    }
    return out
