def lognorm_params_from_bounds(lower, upper):
    """
    Return mu and sigma for a lognormal dist. where lower/upper are p_low/p_high percentiles
    """
    z_low, z_high = -1.96, 1.96
    sigma = (np.log(upper) - np.log(lower)) / 3.92
    mu = (np.log(lower) + np.log(upper)) / 2.0
    return mu, sigma
```


```python
def sample_lognormal_from_bounds(lower, upper, size=1):
    """Get shape and scale for lognorm using Scipy"""
    lower = max(lower, 1e-6)
    upper = max(upper, lower * 1.01)
    mu, sigma = lognorm_params_from_bounds(lower, upper)
    return lognorm(s=sigma, scale=np.exp(mu)).rvs(size=size)
```


```python
def beta_params_from_bounds(mean, low, high):
    sd_approx = (high - low) / 4.0
    var = max(sd_approx ** 2, 1e-8)
    denom = mean * (1 - mean)
    if denom <= 0 or var <= 0:
        return 1.0, 1.0
    ab = max(denom / var - 1.0, 1e-3)
    a = max(mean * ab, 1e-3)
    b = max((1 - mean) * ab, 1e-3)
    return a, b  
```


```python
def pv_annuity(amount_per_year, years, rate=discount_rate):
    if years <= 0:
        return 0.0
    return amount_per_year * ((1 - (1 + rate) **(-years)) / rate)
```


