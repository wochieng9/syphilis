def simulate_disability_weights(mean, std, n_samples=n_iter, random_state=None):
    """
    Simulate disability weights from a Beta distribution with specified mean and sd
    """
    if not 0 < mean < 1:
        raise ValueError("Mean must be between 0 and 1")
    if std <= 0:
        raise ValueError("Standard deviation must be positive")

    variance = std ** 2

    # Max std deviation for given mean
    max_std = np.sqrt(mean * (1-mean))
    if std > max_std:
        raise ValueError(f"Standard deviation too large for mean={mean}. Maximum allowed: {max_std:.4f}")

    # Calc Beta distribution parameters using method of moments
    alpha = ((1 - mean) / variance - 1 /mean) * mean ** 2
    beta_param = alpha * (1/mean - 1)

    # Check validity
    if alpha <= 0 or beta_param <=0:
        raise ValueError(
            f"Invalid parameters: mean={mean} and sd={std} combination"
            f"results in non-positive Beta parameters (alpha={alpha:.4f}, beta={beta_param:.4f})"
        )
    if random_state is not None:
        np.random.seed(random_state)
    samples = beta.rvs(alpha, beta_param, size=n_samples)

    return samples, alpha, beta_param
