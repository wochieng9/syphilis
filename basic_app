colA, colB = st.columns(2)

with colA:
    with st.expander("Baseline outcome risks (Beta priors)", expanded=False):
        baseline_beta = {}
        for k, ab in DEFAULT_BASELINE_BETA.items():
            st.markdown(f"**{k}**")
            a = st.number_input(f"{k} alpha", min_value=0.1, max_value=1e7, value=float(ab["alpha"]), step=1.0, key=f"base_{k}_a")
            b = st.number_input(f"{k} beta", min_value=0.1, max_value=1e7, value=float(ab["beta"]), step=1.0, key=f"base_{k}_b")
            baseline_beta[k] = {"alpha": a, "beta": b}

    with st.expander("Untreated syphilis absolute risks (means)", expanded=False):
        untreated_abs = {}
        for k, v in DEFAULT_UNTREATED_ABS.items():
            untreated_abs[k] = st.number_input(f"{k} mean", min_value=0.0, max_value=1.0, value=float(v), step=0.001, format="%.3f", key=f"unt_{k}")
        untreated_conc = st.number_input(
            "Concentration (pseudo-n) for untreated risks", min_value=10.0, max_value=10000.0, value=1000.0, step=10.0
        )

with colB:
    with st.expander("Treatment relative risks (RR + 95% CI)", expanded=False):
        tx_rr = {}
        for k, d in DEFAULT_TX_RR.items():
            st.markdown(f"**{k}**")
            rr = st.number_input(f"{k} RR", min_value=0.0, max_value=5.0, value=float(d["rr"]), step=0.01, key=f"rr_{k}")
            lo = st.number_input(f"{k} lo", min_value=0.0, max_value=5.0, value=float(d["lo"]), step=0.01, key=f"rr_{k}_lo")
            hi = st.number_input(f"{k} hi", min_value=0.0, max_value=5.0, value=float(d["hi"]), step=0.01, key=f"rr_{k}_hi")
            tx_rr[k] = {"rr": rr, "lo": lo, "hi": hi}

    with st.expander("Costs (mean + SD; Gamma)", expanded=False):
        c = CostInputs()
        # allow editing all fields
        new_vals = {}
        for field, val in asdict(c).items():
            # keep sd separate and small
            if field.endswith("_sd"):
                new_vals[field] = st.number_input(field, min_value=0.0, max_value=1e9, value=float(val), step=1.0)
            else:
                new_vals[field] = st.number_input(field, min_value=0.0, max_value=1e9, value=float(val), step=10.0)
        costs = CostInputs(**new_vals)

# Run & show outputs
if run:
    df, summary = run_simulation(
        n_iter=int(n_iter),
        seed=int(seed),
        cohort=int(cohort),
        p_active_syph=float(p_active_syph),
        screen_baseline=float(screen_baseline),
        screen_enhanced=float(screen_enhanced),
        sens_serology=float(sens_serology),
        spec_serology=float(spec_serology),
        adequate_tx_given_positive=float(adequate_tx_given_positive),
        timely_treatment_fraction=float(timely_treatment_fraction),
        prop_late_fetal=float(prop_late_fetal),
        prop_cs_symptomatic=float(prop_cs_symptomatic),
        untreated_abs=untreated_abs,
        untreated_conc=float(untreated_conc),
        baseline_beta=baseline_beta,
        tx_rr=tx_rr,
        costs=costs,
        discount_rate=float(discount_rate),
        life_expectancy=float(life_expectancy),
        include_lbw=bool(include_lbw),
        include_maternal_burden=bool(include_maternal_burden),
        treat_false_positives=bool(treat_false_positives),
        staff_cost_per_screen=float(staff_cost_per_screen),
    )

    st.subheader("Results")

    c1, c2, c3, c4 = st.columns(4)
    with c1:
        st.metric("Mean ΔCost (HS)", f"${summary['hs_inc_cost']['mean']:,.0f}")
    with c2:
        st.metric("Mean DALYs prevented", f"{summary['dalys_prevented']['mean']:,.0f}")
    with c3:
        st.metric("Mean ICER ($/DALY)", f"${summary['icer_per_daly']['mean']:,.0f}")
    with c4:
        st.metric("P(cost-saving)", f"{100*summary['p_cost_saving']:.1f}%")

    # Outcome prevented table
    st.markdown("### Outcomes prevented (baseline − enhanced)")
    outcome_cols = [c for c in df.columns if c.startswith("Δ ") and c.endswith("(prevented)")]
    rows = []
    for col in outcome_cols:
        summ = summarize(df[col].values)
        rows.append({
            "Outcome": col.replace("Δ ", "").replace(" (prevented)", ""),
            "Mean": summ["mean"],
            "2.5%": summ["2.5%"],
            "97.5%": summ["97.5%"],
        })
    st.dataframe(pd.DataFrame(rows))

    # CE plane
    st.markdown("### Cost-effectiveness plane (health sector)")
    fig, ax = plt.subplots(figsize=(8, 5))

    x = df["disc_dalys_prevented"].values
    y = df["inc_cost_hs"].values

    ax.scatter(x, y, s=2)

    # WTP lines
    for wtp in [50_000, 100_000, 150_000]:
        xs = np.array([x.min(), x.max()])
        ax.plot(xs, wtp * xs, ls="--", label=f"${wtp/1000:.0f}K/DALY")

    for sp in ["top", "right"]:
        ax.spines[sp].set_visible(False)
    ax.spines["left"].set_position(("data", 0))
    ax.spines["bottom"].set_position(("data", 0))

    ax.grid(alpha=0.2)
    ax.xaxis.set_major_formatter(StrMethodFormatter("{x:,.0f}"))
    ax.yaxis.set_major_formatter(ticker.FuncFormatter(millions_formatter))

    ci_ellipse(x, y)

    ax.set_xlabel(r"$\Delta$ DALYs prevented")
    ax.set_ylabel(r"$\Delta$ Cost (HS)")
    ax.set_title("CEA: Enhanced ED screening vs baseline")
    ax.legend(title="WTP threshold", loc="upper right")

    st.pyplot(fig, clear_figure=True)

    # CEAC (NMB-based)
    st.markdown("### CEAC (NMB-based)")
    thresholds = np.arange(1_000, int(wtp_max) + 1, 1_000)
    dalys = df["disc_dalys_prevented"].values
    inc_cost = df["inc_cost_hs"].values

    nmb = thresholds[None, :] * dalys[:, None] - inc_cost[:, None]
    ce_prob = (nmb > 0).mean(axis=0)

    fig2, ax2 = plt.subplots(figsize=(8, 4))
    ax2.plot(thresholds, ce_prob, color="k")
    ax2.grid(alpha=0.2)
    for sp in ["top", "right"]:
        ax2.spines[sp].set_visible(False)
    ax2.set_ylim(0, 1)
    ax2.set_xlabel("WTP ($/DALY)")
    ax2.set_ylabel("Probability cost-effective")
    ax2.xaxis.set_major_formatter(ticker.FuncFormatter(dollar_formatter))
    ax2.set_title("Cost-effectiveness acceptability curve")
    st.pyplot(fig2, clear_figure=True)

    # Download CSV
    st.subheader("Download")
    csv_bytes = df.to_csv(index=False).encode("utf-8")
    st.download_button(
        label="Download simulation results as CSV",
        data=csv_bytes,
        file_name="syphilis_screening_cea_results.csv",
        mime="text/csv",
    )
else:
    st.info("Set inputs in the sidebar and click **Run simulation**.")
