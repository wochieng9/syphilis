def ln_params_from_ci(m: float, lo: float, hi: float) -> Tuple[float, float]:
    """Lognormal params for RR given median-ish m and 95% bounds."""
    lo = max(lo, 1e-12)
    hi = max(hi, lo * 1.01)
    sigma = (np.log(hi) - np.log(lo)) / (2 * 1.96)
    mu = np.log(m)
    return mu, sigma


def draw_baseline_beta(alpha: float, beta_b: float, size: int, rs: np.random.RandomState) -> np.ndarray:
    return beta(alpha, beta_b).rvs(size=size, random_state=rs)


def beta_from_mean(mean: float, n: float, size: int, rs: np.random.RandomState) -> np.ndarray:
    """Beta around mean with concentration n (pseudo-sample size)."""
    mean = min(max(float(mean), 1e-6), 1 - 1e-6)
    a = mean * n
    b = (1 - mean) * n
    return beta(a, b).rvs(size=size, random_state=rs)


def simulate_strategy(
    *,
    screen_cov: float,
    cohort: int,
    p_active_syph: float,
    sens_serology: float,
    adequate_tx_given_positive: float,
    timely_treatment_fraction: float,
    prop_late_fetal: float,
    prop_cs_symptomatic: float,
    # pre-sampled arrays (common random numbers)
    b_preterm: np.ndarray,
    b_lbw: np.ndarray,
    b_still: np.ndarray,
    b_neo: np.ndarray,
    b_mis: np.ndarray,
    u_preterm: np.ndarray,
    u_lbw: np.ndarray,
    u_still: np.ndarray,
    u_neo: np.ndarray,
    u_mis: np.ndarray,
    u_cs: np.ndarray,
    rr_preterm: np.ndarray,
    rr_lbw: np.ndarray,
    rr_still: np.ndarray,
    rr_neo: np.ndarray,
    rr_cs: np.ndarray,
) -> Dict[str, np.ndarray]:

    p_detect = screen_cov * sens_serology
    p_adequate = p_detect * adequate_tx_given_positive * timely_treatment_fraction

    preterm_syph = p_adequate * (u_preterm * rr_preterm) + (1 - p_adequate) * u_preterm
    lbw_syph = p_adequate * (u_lbw * rr_lbw) + (1 - p_adequate) * u_lbw
    still_syph = p_adequate * (u_still * rr_still) + (1 - p_adequate) * u_still
    neo_syph = p_adequate * (u_neo * rr_neo) + (1 - p_adequate) * u_neo
    mis_syph = u_mis  # unchanged

    cs_any_syph = p_adequate * (u_cs * rr_cs) + (1 - p_adequate) * u_cs
    cs_comp_syph = cs_any_syph * prop_cs_symptomatic
    cs_uncomp_syph = cs_any_syph * (1 - prop_cs_symptomatic)

    p = p_active_syph

    # mix syph vs non-syph
    preterm = p * preterm_syph + (1 - p) * b_preterm
    lbw = p * lbw_syph + (1 - p) * b_lbw
    still = p * still_syph + (1 - p) * b_still
    neo = p * neo_syph + (1 - p) * b_neo
    mis = p * mis_syph + (1 - p) * b_mis

    # IUFD is subset of stillbirth
    iufd = still * prop_late_fetal

    # CS occurs only in syph pregnancies in this model
    cs_comp = p * cs_comp_syph
    cs_uncomp = p * cs_uncomp_syph

    def to_counts(prob_arr: np.ndarray) -> np.ndarray:
        return np.round(prob_arr * cohort).astype(int)

    return {
        "Preterm births": to_counts(preterm),
        "Low birth weight": to_counts(lbw),
        "Stillbirths (≥20w)": to_counts(still),
        "IUFD (≥28w subset)": to_counts(iufd),
        "Miscarriages (<20w clinical)": to_counts(mis),
        "Neonatal deaths (<28d)": to_counts(neo),
        "Congenital syphilis – complicated": to_counts(cs_comp),
        "Congenital syphilis – uncomplicated": to_counts(cs_uncomp),
    }


def run_simulation(
    *,
    n_iter: int,
    seed: int,
    cohort: int,
    p_active_syph: float,
    screen_baseline: float,
    screen_enhanced: float,
    sens_serology: float,
    spec_serology: float,
    adequate_tx_given_positive: float,
    timely_treatment_fraction: float,
    prop_late_fetal: float,
    prop_cs_symptomatic: float,
    untreated_abs: Dict[str, float],
    untreated_conc: float,
    baseline_beta: Dict[str, Dict[str, float]],
    tx_rr: Dict[str, Dict[str, float]],
    costs: CostInputs,
    discount_rate: float,
    life_expectancy: float,
    include_lbw: bool,
    include_maternal_burden: bool,
    treat_false_positives: bool,
    staff_cost_per_screen: float,
) -> Tuple[pd.DataFrame, Dict[str, Dict[str, float]]]:

    rs = np.random.RandomState(seed)

    # Pre-sample baseline risks
    b_preterm = draw_baseline_beta(baseline_beta["preterm"]["alpha"], baseline_beta["preterm"]["beta"], n_iter, rs)
    b_lbw = draw_baseline_beta(baseline_beta["lbw"]["alpha"], baseline_beta["lbw"]["beta"], n_iter, rs)
    b_still = draw_baseline_beta(baseline_beta["stillbirth"]["alpha"], baseline_beta["stillbirth"]["beta"], n_iter, rs)
    b_neo = draw_baseline_beta(baseline_beta["neonatal_death"]["alpha"], baseline_beta["neonatal_death"]["beta"], n_iter, rs)
    b_mis = draw_baseline_beta(baseline_beta["miscarriage"]["alpha"], baseline_beta["miscarriage"]["beta"], n_iter, rs)

    # Untreated abs risks sampled around mean with pseudo n
    u_preterm = beta_from_mean(untreated_abs["preterm"], untreated_conc, n_iter, rs)
    u_lbw = beta_from_mean(untreated_abs["lbw"], untreated_conc, n_iter, rs)
    u_still = beta_from_mean(untreated_abs["stillbirth"], untreated_conc, n_iter, rs)
    u_neo = beta_from_mean(untreated_abs["neonatal_death"], untreated_conc, n_iter, rs)
    u_mis = beta_from_mean(untreated_abs["miscarriage"], untreated_conc, n_iter, rs)
    u_cs = beta_from_mean(untreated_abs["cs_any"], untreated_conc, n_iter, rs)

    # Treatment RR lognormal draws
    def draw_rr(key: str) -> np.ndarray:
        mu, sigma = ln_params_from_ci(tx_rr[key]["rr"], tx_rr[key]["lo"], tx_rr[key]["hi"])
        return lognorm(s=sigma, scale=np.exp(mu)).rvs(size=n_iter, random_state=rs)

    rr_preterm = draw_rr("preterm")
    rr_lbw = draw_rr("lbw")
    rr_still = draw_rr("stillbirth")
    rr_neo = draw_rr("neonatal_death")
    rr_cs = draw_rr("cs_any")

    out_base = simulate_strategy(
        screen_cov=screen_baseline,
        cohort=cohort,
        p_active_syph=p_active_syph,
        sens_serology=sens_serology,
        adequate_tx_given_positive=adequate_tx_given_positive,
        timely_treatment_fraction=timely_treatment_fraction,
        prop_late_fetal=prop_late_fetal,
        prop_cs_symptomatic=prop_cs_symptomatic,
        b_preterm=b_preterm,
        b_lbw=b_lbw,
        b_still=b_still,
        b_neo=b_neo,
        b_mis=b_mis,
        u_preterm=u_preterm,
        u_lbw=u_lbw,
        u_still=u_still,
        u_neo=u_neo,
        u_mis=u_mis,
        u_cs=u_cs,
        rr_preterm=rr_preterm,
        rr_lbw=rr_lbw,
        rr_still=rr_still,
        rr_neo=rr_neo,
        rr_cs=rr_cs,
    )

    out_int = simulate_strategy(
        screen_cov=screen_enhanced,
        cohort=cohort,
        p_active_syph=p_active_syph,
        sens_serology=sens_serology,
        adequate_tx_given_positive=adequate_tx_given_positive,
        timely_treatment_fraction=timely_treatment_fraction,
        prop_late_fetal=prop_late_fetal,
        prop_cs_symptomatic=prop_cs_symptomatic,
        b_preterm=b_preterm,
        b_lbw=b_lbw,
        b_still=b_still,
        b_neo=b_neo,
        b_mis=b_mis,
        u_preterm=u_preterm,
        u_lbw=u_lbw,
        u_still=u_still,
        u_neo=u_neo,
        u_mis=u_mis,
        u_cs=u_cs,
        rr_preterm=rr_preterm,
        rr_lbw=rr_lbw,
        rr_still=rr_still,
        rr_neo=rr_neo,
        rr_cs=rr_cs,
    )

    # Δ prevented = baseline - intervention
    delta = {k: (np.asarray(out_base[k]) - np.asarray(out_int[k])) for k in out_base.keys()}
    df = pd.DataFrame({f"Δ {k} (prevented)": v for k, v in delta.items()})
    df["iteration"] = np.arange(n_iter)

    # ---------- Costs: draw gamma samples per iteration ----------
    cost_dict = asdict(costs)
    cost_samples = {}
    for k, v in cost_dict.items():
        if k.endswith("_sd"):
            continue
        sd_key = f"{k}_sd"
        if sd_key in cost_dict:
            shape, scale = gamma_from_mean_sd(cost_dict[k], cost_dict[sd_key])
            cost_samples[k] = gamma(a=shape, scale=scale).rvs(size=n_iter, random_state=rs)
        else:
            cost_samples[k] = np.full(n_iter, float(v))

    # ---------- DALYs prevented (discounted) ----------
    pv_L = pv_years(life_expectancy, discount_rate)
    pv_1 = pv_years(1.0, discount_rate)

    # YLL: stillbirth + neonatal death
    still = df["Δ Stillbirths (≥20w) (prevented)"].values
    neo = df["Δ Neonatal deaths (<28d) (prevented)"].values

    daly_yll_still = still * pv_L
    daly_yll_neo = neo * pv_L

    # YLD: congenital syphilis acute/lt
    cs_un = df["Δ Congenital syphilis – uncomplicated (prevented)"].values
    cs_co = df["Δ Congenital syphilis – complicated (prevented)"].values

    # DW sampling for complicated CS
    a_cs, b_cs = beta_params_from_bounds(0.315, 0.159, 0.471)
    dw_cs_comp = beta(a_cs, b_cs).rvs(size=n_iter, random_state=rs)

    dw_cs_uncomp = 0.053
    dur_uncomp = 0.25
    dur_comp = 1.0

    daly_yld_cs_un = cs_un * (dw_cs_uncomp * pv_years(dur_uncomp, discount_rate))
    daly_yld_cs_comp = cs_co * (dw_cs_comp * pv_years(dur_comp, discount_rate))

    # LT sequelae (scenario)
    p_cs_lt = 0.20
    dw_cs_lt = 0.100
    daly_yld_cs_lt = (p_cs_lt * cs_co) * (dw_cs_lt * pv_years(70.0, discount_rate))

    # Optional LBW YLD
    if include_lbw:
        lbw = df["Δ Low birth weight (prevented)"].values
        dw_lbw = 0.106
        daly_yld_lbw = lbw * (dw_lbw * pv_years(0.25, discount_rate))
    else:
        daly_yld_lbw = np.zeros(n_iter)

    # Optional maternal grief YLD
    if include_maternal_burden:
        a_sb, b_sb = beta_params_from_bounds(0.74, 0.60, 0.80)
        a_nd, b_nd = beta_params_from_bounds(0.658, 0.528, 0.768)
        dw_mom_sb = beta(a_sb, b_sb).rvs(size=n_iter, random_state=rs)
        dw_mom_nd = beta(a_nd, b_nd).rvs(size=n_iter, random_state=rs)
        daly_mom = still * (dw_mom_sb * pv_1) + neo * (dw_mom_nd * pv_1)
    else:
        daly_mom = np.zeros(n_iter)

    dalys_total = (
        daly_yll_still
        + daly_yll_neo
        + daly_yld_cs_un
        + daly_yld_cs_comp
        + daly_yld_cs_lt
        + daly_yld_lbw
        + daly_mom
    )

    df["disc_dalys_prevented"] = dalys_total

    # ---------- Outcome cost savings (HS) ----------
    # IMPORTANT: IUFD is subset of stillbirth in your model; do not sum both.
    savings_still = still * cost_samples["stillborn_term_cost"]
    savings_neo = neo * cost_samples["nnd_preterm_cost"]

    savings_cs_un = cs_un * cost_samples["workup_cs_cost"]
    savings_cs_co = cs_co * (cost_samples["workup_cs_cost"] + cost_samples["cs_lifetime_hs_cost"])

    if include_lbw:
        lbw = df["Δ Low birth weight (prevented)"].values
        savings_lbw = lbw * cost_samples["lbw_hs_costs"]
    else:
        savings_lbw = np.zeros(n_iter)

    savings_total = savings_still + savings_neo + savings_cs_un + savings_cs_co + savings_lbw
    df["hs_savings"] = savings_total

    # ---------- Incremental program costs ----------
    delta_screened = max(screen_enhanced - screen_baseline, 0.0) * cohort

    # test costs: RPR for all additional screened; confirmatory FTA for positives
    rpr = cost_samples["rpr_cost"]
    fta = cost_samples["fta_cost"]
    pen = cost_samples["penicillin_cost"]

    p_pos = p_active_syph * sens_serology + (1 - p_active_syph) * (1 - spec_serology)

    inc_test = delta_screened * rpr + (delta_screened * p_pos) * fta

    tp = delta_screened * p_active_syph * sens_serology
    fp = delta_screened * (1 - p_active_syph) * (1 - spec_serology)

    if treat_false_positives:
        n_treated = (tp + fp) * adequate_tx_given_positive
    else:
        n_treated = tp * adequate_tx_given_positive

    inc_tx = n_treated * pen

    inc_staff = delta_screened * staff_cost_per_screen

    inc_program = inc_test + inc_tx + inc_staff
    df["inc_program_cost_hs"] = inc_program

    # ---------- Incremental cost and ICER ----------
    inc_cost_hs = inc_program - savings_total
    df["inc_cost_hs"] = inc_cost_hs

    eps = 1e-12
    df["icer_hs_per_daly"] = df["inc_cost_hs"] / np.maximum(df["disc_dalys_prevented"], eps)

    # ---------- Summaries ----------
    summary = {
        "hs_inc_cost": summarize(df["inc_cost_hs"].values),
        "dalys_prevented": summarize(df["disc_dalys_prevented"].values),
        "icer_per_daly": summarize(df["icer_hs_per_daly"].replace([np.inf, -np.inf], np.nan).dropna().values),
        "p_cost_saving": float((df["inc_cost_hs"].values < 0).mean()),
    }

    return df, summary


