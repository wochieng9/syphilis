def dollar_formatter(x, pos):
    return f"${x:,.0f}"


def millions_formatter(x, pos):
    return f"${x * 1e-6:,.0f}M"


def ci_ellipse(x, y, edgecolor="k"):
    """Draw a 95% confidence ellipse around x/y values on the current axes."""
    x = np.asarray(x)
    y = np.asarray(y)
    if len(x) < 3:
        return None

    mean = np.array([np.mean(x), np.mean(y)])
    cov = np.cov(x, y)

    # covariance is symmetric -> eigh gives stable ordering
    eigenvalues, eigenvectors = np.linalg.eigh(cov)
    order = np.argsort(eigenvalues)[::-1]
    eigenvalues = eigenvalues[order]
    eigenvectors = eigenvectors[:, order]

    angle = np.arctan2(eigenvectors[1, 0], eigenvectors[0, 0])

    # chi2 quantile for 2 df at 95%
    chi2_95 = 5.991
    width = 2 * np.sqrt(eigenvalues[0] * chi2_95)
    height = 2 * np.sqrt(eigenvalues[1] * chi2_95)

    ell = Ellipse(
        xy=mean,
        width=width,
        height=height,
        angle=np.rad2deg(angle),
        edgecolor=edgecolor,
        facecolor="None",
        lw=1,
    )
    plt.gca().add_patch(ell)
    return ell


def std_2(lower_ci, upper_ci):
    """Approx SD from 95% interval bounds."""
    return (upper_ci - lower_ci) / 4.0


def pv_years(years: float, r: float) -> float:
    if years <= 0:
        return 0.0
    if r == 0:
        return float(years)
    return float((1 - (1 + r) ** (-years)) / r)


def pv_annuity(amount_per_year: float, years: float, r: float) -> float:
    return amount_per_year * pv_years(years, r)


def lognorm_params_from_bounds(lower: float, upper: float) -> Tuple[float, float]:
    """Return mu and sigma for lognormal where lower/upper ~ 2.5% and 97.5%."""
    lower = max(lower, 1e-12)
    upper = max(upper, lower * 1.01)
    sigma = (np.log(upper) - np.log(lower)) / 3.92
    mu = (np.log(lower) + np.log(upper)) / 2.0
    return mu, sigma


def sample_lognormal_from_bounds(lower: float, upper: float, size: int, rs: np.random.RandomState) -> np.ndarray:
    mu, sigma = lognorm_params_from_bounds(lower, upper)
    return lognorm(s=sigma, scale=np.exp(mu)).rvs(size=size, random_state=rs)


def beta_params_from_bounds(mean: float, low: float, high: float) -> Tuple[float, float]:
    """Method-of-moments beta fit using low/high as ~95% bounds."""
    mean = float(mean)
    mean = min(max(mean, 1e-6), 1 - 1e-6)

    sd_approx = float((high - low) / 4.0)
    var = max(sd_approx**2, 1e-10)

    denom = mean * (1 - mean)
    ab = max(denom / var - 1.0, 1e-3)
    a = max(mean * ab, 1e-3)
    b = max((1 - mean) * ab, 1e-3)
    return a, b


def gamma_from_mean_sd(mean: float, sd: float) -> Tuple[float, float]:
    """Return (shape, scale) for Gamma with given mean and sd."""
    mean = float(mean)
    sd = float(sd)
    sd = max(sd, 1e-9)
    shape = (mean / sd) ** 2
    scale = (sd**2) / mean
    return shape, scale


def summarize(arr: np.ndarray) -> Dict[str, float]:
    arr = np.asarray(arr)
    return {
        "mean": float(np.mean(arr)),
        "median": float(np.median(arr)),
        "2.5%": float(np.percentile(arr, 2.5)),
        "97.5%": float(np.percentile(arr, 97.5)),
    }


